# Copy to `.env` and adjust for each machine (`.env` is usually gitignored).

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=snh6_swiftproject

SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production
# Login token lifetime in seconds (900 = 15 minutes)
JWT_ACCESS_TOKEN_EXPIRES=900

# Email — set here OR via Windows CMD before starting the server:
#   set MAIL_USERNAME=your_email@gmail.com
#   set MAIL_PASSWORD=your_app_password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=rajubhaaikar@gmail.com
MAIL_PASSWORD=wpyy hxlx asbf pyjw
MAIL_DEFAULT_SENDER=rajubhaaikar@gmail.com

# Secure document upload (VAPT)
UPLOAD_MAX_BYTES=26214400
UPLOAD_MALWARE_SCAN=true
