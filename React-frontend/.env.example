# Copy to `.env` or `.env.local` only when you need overrides.

# --- Local dev (default): leave BOTH unset ---
# The app calls `/api` on the Vite dev server (same tab origin); vite.config proxies to Flask.
# Run backend: python_backend `python app.py` (Flask on port 5000 by default).

# If Flask runs elsewhere (different port or host), set proxy target only:
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# To point the SPA at a remote/staging API instead of the proxy (skip local Flask):
# VITE_API_URL=https://your-api.example.com/

# Secret for encoding numeric IDs in vendor panel URLs (change in production).
# VITE_URL_ID_SECRET=your-random-secret-here
